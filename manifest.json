{
    "manifest_version": 3,
    "name": "Producer.ai Download Suite (Clean)",
    "version": "3.8",
    "description": "Complete downloading toolkit.",
    "permissions": [
        "activeTab",
        "scripting",
        "downloads",
        "storage"
    ],
    "host_permissions": [
        "https://www.producer.ai/*"
    ],
    "background": {
        "service_worker": "bg.js"
    },
    "action": {
        "default_title": "Open Sidebar"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.producer.ai/*"
            ],
            "css": [
                "styles.css"
            ],
            "js": [
                "jszip.min.js",
                "content.js",
                "downloader.js",
                "sidebar_ui.js"
            ]
        }
    ]
}